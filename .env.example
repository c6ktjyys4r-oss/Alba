# Copy to .env and fill in values from your Manus project / Render dashboard.
# VITE_* vars must be set on Render before building OR at runtime (the server
# injects them into the HTML when serving the app).

# Database
DATABASE_URL=mysql://user:password@host:3306/alba

# Auth (required — missing values cause "TypeError: Invalid URL" on login)
JWT_SECRET=change-me-to-a-long-random-string
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
OWNER_OPEN_ID=

# Manus built-in APIs (storage, LLM, maps, etc.)
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im
VITE_FRONTEND_FORGE_API_KEY=

# Optional analytics (leave empty to disable)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Server
PORT=3000
NODE_ENV=development
