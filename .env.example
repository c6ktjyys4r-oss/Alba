# Copy to .env and fill in values for your deployment.

# Database (required)
DATABASE_URL=mysql://user:password@host:3306/alba

# Session Security (required)
JWT_SECRET=change-me-to-a-long-random-string

# OAuth (optional - leave empty for standalone mode)
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=

# External APIs (optional - leave empty to disable features)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional analytics (leave empty to disable)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Server
PORT=3000
NODE_ENV=development
